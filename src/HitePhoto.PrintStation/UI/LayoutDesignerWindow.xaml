<Window x:Class="HitePhoto.PrintStation.UI.LayoutDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Layout Designer"
        Width="920" Height="680"
        MinWidth="750" MinHeight="550"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Form fields -->
        <Border Grid.Column="0" Background="{DynamicResource PanelBg}" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
                <StackPanel>

                    <TextBlock Text="Layout Name" FontWeight="SemiBold" FontSize="12"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="NameBox" Margin="0,0,0,14"/>

                    <TextBlock Text="Individual Print Size" FontWeight="SemiBold" FontSize="12"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Width (in)" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                            <TextBox x:Name="PrintWidthBox" Width="90" TextChanged="Field_Changed"/>
                        </StackPanel>
                        <TextBlock Text=" x " VerticalAlignment="Bottom"
                                   Foreground="{DynamicResource TextSecondary}" Margin="8,0,8,6"/>
                        <StackPanel>
                            <TextBlock Text="Height (in)" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                            <TextBox x:Name="PrintHeightBox" Width="90" TextChanged="Field_Changed"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Grid Arrangement" FontWeight="SemiBold" FontSize="12"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Rows" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                            <ComboBox x:Name="RowsCombo" Width="60" SelectionChanged="Field_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Margin="16,0,0,0">
                            <TextBlock Text="Columns" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                            <ComboBox x:Name="ColumnsCombo" Width="60" SelectionChanged="Field_SelectionChanged"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Spacing (inches)" FontWeight="SemiBold" FontSize="12"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Gap horizontal"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                        <TextBox x:Name="GapHBox" Grid.Row="1" Grid.Column="0" TextChanged="Field_Changed"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Gap vertical"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                        <TextBox x:Name="GapVBox" Grid.Row="1" Grid.Column="2" TextChanged="Field_Changed"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Offset before" Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                        <TextBox x:Name="OffsetBeforeBox" Grid.Row="3" Grid.Column="0" TextChanged="Field_Changed"/>

                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Margin around" Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                        <TextBox x:Name="MarginAroundBox" Grid.Row="3" Grid.Column="2"
                                 ToolTip="Sets all four margins equally" TextChanged="MarginAround_Changed"/>

                        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                                    Orientation="Horizontal" Margin="0,6,0,0">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="L" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                <TextBox x:Name="MarginLeftBox" Width="50" TextChanged="Field_Changed"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="R" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                <TextBox x:Name="MarginRightBox" Width="50" TextChanged="Field_Changed"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="T" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                <TextBox x:Name="MarginTopBox" Width="50" TextChanged="Field_Changed"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="B" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                <TextBox x:Name="MarginBottomBox" Width="50" TextChanged="Field_Changed"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Auto-Match Sizes" FontWeight="SemiBold" FontSize="12"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="AutoMatchBox"
                             ToolTip="Comma-separated size labels, e.g. 2x3, wallet"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Target Channel" FontWeight="SemiBold" FontSize="12"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ChannelCombo" Margin="0,0,0,14"
                              SelectionChanged="Field_SelectionChanged"/>

                    <Border Background="{DynamicResource SurfaceBg}" CornerRadius="4"
                            Padding="10,8" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Calculated Page Size"
                                       Foreground="{DynamicResource TextMuted}" FontSize="10"/>
                            <TextBlock x:Name="CalcPageSizeText" FontSize="16"
                                       FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="SizeMatchText" FontSize="11" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="SaveBtn" Content="Save Layout" Width="120"
                                Margin="0,0,8,0" Click="SaveBtn_Click"/>
                        <Button Content="Cancel" Width="80" Click="CancelBtn_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- RIGHT PANEL: Live preview -->
        <Border Grid.Column="1" Background="{DynamicResource WindowBg}" Margin="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Preview" FontSize="12"
                           Foreground="{DynamicResource TextSecondary}" Margin="10,6"/>
                <Border Grid.Row="1" Margin="10" Background="#FFFFFF" CornerRadius="2"
                        x:Name="PreviewBorder">
                    <Canvas x:Name="PreviewCanvas" ClipToBounds="True"
                            SizeChanged="PreviewCanvas_SizeChanged"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
