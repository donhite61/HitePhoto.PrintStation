<Window x:Class="HitePhoto.PrintStation.UI.SendForProductionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Send for Production" Width="520" Height="480"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource WindowBg}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="OrderHeader" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock x:Name="OrderDetail" FontSize="12"
                       Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Select all / none -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="Items to send:" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimary}"/>
            <Button Content="All" Width="40" Margin="12,0,4,0" Click="SelectAll_Click"
                    FontSize="11" Padding="4,1"/>
            <Button Content="None" Width="44" Click="SelectNone_Click"
                    FontSize="11" Padding="4,1"/>
        </StackPanel>

        <!-- Item checkboxes grouped by size -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ItemPanel" Margin="8,4"/>
            </ScrollViewer>
        </Border>

        <!-- Folders section -->
        <StackPanel Grid.Row="3" Margin="0,8,0,0">
            <TextBlock Text="Folders to send:" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
            <StackPanel x:Name="FolderPanel" Margin="8,4,0,0"/>
        </StackPanel>

        <!-- Target store + create order -->
        <StackPanel Grid.Row="4" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal">
                <Label Content="Send to:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                <ComboBox x:Name="StoreCombo" Width="200" Margin="4,0,0,0"
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>
            </StackPanel>
            <CheckBox x:Name="CreateOrderCheck" Content="Create work order (-W#)"
                      IsChecked="True" Margin="0,6,0,0" FontSize="12"
                      Foreground="{DynamicResource TextPrimary}"/>
        </StackPanel>

        <!-- Comment -->
        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Message:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
            <TextBox x:Name="CommentBox" Grid.Column="1" Margin="4,0,0,0"
                     FontSize="12" VerticalAlignment="Center"/>
        </Grid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="SummaryText" VerticalAlignment="Center" Margin="0,0,12,0"
                       FontSize="11" Foreground="{DynamicResource TextMuted}"/>
            <Button x:Name="SendBtn" Content="Send" Width="100" Height="32"
                    Click="Send_Click" IsEnabled="False" FontWeight="SemiBold"/>
            <Button Content="Cancel" Width="80" Height="32" Margin="8,0,0,0"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
