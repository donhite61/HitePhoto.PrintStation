<Window x:Class="HitePhoto.PrintStation.UI.OrderHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Order History"
        Width="600" Height="400"
        MinWidth="400" MinHeight="200"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBg}" Padding="8,5">
            <TextBlock x:Name="HeaderText" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"/>
        </Border>

        <ListView x:Name="HistoryListView" FontSize="12"
                  Background="{DynamicResource PanelBg}"
                  BorderBrush="{DynamicResource BorderBrush}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Date" Width="140"
                                    DisplayMemberBinding="{Binding CreatedAt}"/>
                    <GridViewColumn Header="By" Width="80"
                                    DisplayMemberBinding="{Binding CreatedBy}"/>
                    <GridViewColumn Header="Note" Width="340"
                                    DisplayMemberBinding="{Binding Note}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
