<Window x:Class="HitePhoto.PrintStation.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrintStation Settings"
        Width="500" Height="550"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBg}"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Buttons -->
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Database Connection -->
                <TextBlock Text="Database Connection" Foreground="{DynamicResource TextHeading}"
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Host:" Foreground="{DynamicResource TextLabel}" VerticalAlignment="Center"/>
                    <TextBox x:Name="DbHostBox" Grid.Column="1"
                             Background="{DynamicResource InputBg}" Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource InputBorder}" Padding="4,3"/>
                </Grid>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Port:" Foreground="{DynamicResource TextLabel}" VerticalAlignment="Center"/>
                    <TextBox x:Name="DbPortBox" Grid.Column="1"
                             Background="{DynamicResource InputBg}" Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource InputBorder}" Padding="4,3"/>
                </Grid>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Database:" Foreground="{DynamicResource TextLabel}" VerticalAlignment="Center"/>
                    <TextBox x:Name="DbNameBox" Grid.Column="1"
                             Background="{DynamicResource InputBg}" Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource InputBorder}" Padding="4,3"/>
                </Grid>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="User:" Foreground="{DynamicResource TextLabel}" VerticalAlignment="Center"/>
                    <TextBox x:Name="DbUserBox" Grid.Column="1"
                             Background="{DynamicResource InputBg}" Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource InputBorder}" Padding="4,3"/>
                </Grid>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Password:" Foreground="{DynamicResource TextLabel}" VerticalAlignment="Center"/>
                    <PasswordBox x:Name="DbPasswordBox" Grid.Column="1"
                                 Background="{DynamicResource InputBg}" Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource InputBorder}" Padding="4,3"/>
                </Grid>

                <Button Content="Test Connection" Margin="100,4,0,0" HorizontalAlignment="Left"
                        Click="TestConnectionButton_Click"/>
                <TextBlock x:Name="ConnectionTestResult" Foreground="{DynamicResource TextSecondary}"
                           Margin="100,4,0,0" FontSize="11"/>

                <Border Height="1" Background="{DynamicResource SeparatorBg}" Margin="0,12"/>

                <!-- Store -->
                <TextBlock Text="Store" Foreground="{DynamicResource TextHeading}"
                           FontSize="14" FontWeight="SemiBold" Margin="0,8,0,8"/>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="This Store:" Foreground="{DynamicResource TextLabel}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="StoreCombo" Grid.Column="1"
                              Background="{DynamicResource InputBg}" Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource InputBorder}"/>
                </Grid>

                <Border Height="1" Background="{DynamicResource SeparatorBg}" Margin="0,12"/>

                <!-- Noritsu -->
                <TextBlock Text="Noritsu" Foreground="{DynamicResource TextHeading}"
                           FontSize="14" FontWeight="SemiBold" Margin="0,8,0,8"/>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Output Root:" Foreground="{DynamicResource TextLabel}" VerticalAlignment="Center"/>
                    <TextBox x:Name="NoritsuOutputBox" Grid.Column="1"
                             Background="{DynamicResource InputBg}" Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource InputBorder}" Padding="4,3"/>
                </Grid>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Channels CSV:" Foreground="{DynamicResource TextLabel}" VerticalAlignment="Center"/>
                    <TextBox x:Name="ChannelsCsvBox" Grid.Column="1"
                             Background="{DynamicResource InputBg}" Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource InputBorder}" Padding="4,3"/>
                </Grid>

                <Border Height="1" Background="{DynamicResource SeparatorBg}" Margin="0,12"/>

                <!-- Display -->
                <TextBlock Text="Display" Foreground="{DynamicResource TextHeading}"
                           FontSize="14" FontWeight="SemiBold" Margin="0,8,0,8"/>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Theme:" Foreground="{DynamicResource TextLabel}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ThemeCombo" Grid.Column="1"
                              Background="{DynamicResource InputBg}" Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource InputBorder}">
                        <ComboBoxItem Content="Dark"/>
                        <ComboBoxItem Content="Light"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Refresh (sec):" Foreground="{DynamicResource TextLabel}" VerticalAlignment="Center"/>
                    <TextBox x:Name="RefreshIntervalBox" Grid.Column="1"
                             Background="{DynamicResource InputBg}" Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource InputBorder}" Padding="4,3"/>
                </Grid>

                <CheckBox x:Name="DevModeCheck" Content="Developer Mode"
                          Foreground="{DynamicResource TextPrimary}" Margin="0,8,0,0"/>

                <CheckBox x:Name="LoggingCheck" Content="Enable Logging"
                          Foreground="{DynamicResource TextPrimary}" Margin="0,4,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Width="80" Margin="0,0,8,0" Click="SaveButton_Click"
                    Background="{DynamicResource ButtonPrintBg}"/>
            <Button Content="Cancel" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
