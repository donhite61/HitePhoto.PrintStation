<Window x:Class="HitePhoto.PrintStation.UI.ChangeSizeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preview"
        Width="1100" Height="720"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{DynamicResource ToolbarBg}" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="SizeTitleText" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Send to:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,8,0"/>
                <ComboBox x:Name="ChannelCombo" Width="380" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Image grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{DynamicResource PanelBg}" Padding="8">
            <WrapPanel x:Name="ImageGrid" Orientation="Horizontal"/>
        </ScrollViewer>

        <!-- Bottom bar -->
        <Border Grid.Row="2" Background="{DynamicResource ToolbarBg}" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="CheckAllBox" Content="Check all items"
                              IsChecked="True"
                              VerticalAlignment="Center" Margin="0,0,20,0"
                              Checked="CheckAllBox_Checked" Unchecked="CheckAllBox_Unchecked"/>
                    <TextBlock x:Name="SelectionStatus" Foreground="{DynamicResource TextSecondary}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <CheckBox x:Name="CloseWhenPrintedBox" Content="Close when printed"
                              IsChecked="True" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button x:Name="PrintBtn" Content="Print"
                            Width="100" Height="34" Margin="0,0,8,0"
                            Background="{DynamicResource ButtonPrintBg}"
                            Click="PrintBtn_Click"/>
                    <Button Content="Close" Width="80" Height="34"
                            Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
