<Window x:Class="HitePhoto.PrintStation.UI.TransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transfer Order" Width="800" Height="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource WindowBg}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="OrderHeader" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock x:Name="OrderDetail" FontSize="12"
                       Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Target store selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Label Content="Transfer to:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
            <ComboBox x:Name="StoreCombo" Width="200" Margin="4,0,0,0"
                      DisplayMemberPath="Name" SelectedValuePath="Id"/>
            <Button Content="Connect" Width="80" Margin="12,0,0,0" Click="Connect_Click"/>
            <TextBlock x:Name="ConnectionStatus" VerticalAlignment="Center" Margin="8,0,0,0"
                       FontSize="11" Foreground="{DynamicResource TextMuted}"/>
        </StackPanel>

        <!-- Two-pane view -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Local files -->
            <GroupBox Grid.Column="0" Header="Local Files" Foreground="{DynamicResource TextSecondary}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="LocalPath" Grid.Row="0" FontSize="10"
                               Foreground="{DynamicResource TextMuted}" Margin="4,2" TextTrimming="CharacterEllipsis"/>
                    <ListBox x:Name="LocalFileList" Grid.Row="1" FontFamily="Consolas" FontSize="11"
                             SelectionMode="Extended" Background="{DynamicResource WindowBg}"
                             Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="LocalSummary" Grid.Row="2" FontSize="11"
                               Foreground="{DynamicResource TextMuted}" Margin="4,2"/>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Remote files -->
            <GroupBox Grid.Column="2" Header="Remote Files (target store)" Foreground="{DynamicResource TextSecondary}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="RemotePath" Grid.Row="0" FontSize="10"
                               Foreground="{DynamicResource TextMuted}" Margin="4,2" TextTrimming="CharacterEllipsis"/>
                    <ListBox x:Name="RemoteFileList" Grid.Row="1" FontFamily="Consolas" FontSize="11"
                             SelectionMode="Extended" Background="{DynamicResource WindowBg}"
                             Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="RemoteSummary" Grid.Row="2" FontSize="11"
                               Foreground="{DynamicResource TextMuted}" Margin="4,2"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Comment -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Comment:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
            <TextBox x:Name="CommentBox" Grid.Column="1" Margin="4,0,0,0"
                     FontSize="12" VerticalAlignment="Center"/>
        </Grid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="TransferStatus" VerticalAlignment="Center" Margin="0,0,12,0"
                       FontSize="11" Foreground="{DynamicResource TextMuted}"/>
            <Button x:Name="TransferBtn" Content="Transfer All Files" Width="140" Height="32"
                    Click="Transfer_Click" IsEnabled="False" FontWeight="SemiBold"/>
            <Button Content="Cancel" Width="80" Height="32" Margin="8,0,0,0"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
