<Window x:Class="HitePhoto.PrintStation.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HitePhoto.PrintStation.UI"
        Title="HitePhoto Print Station"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="550"
        Background="{DynamicResource WindowBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Main content -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Toolbar ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource ToolbarBg}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Source filter -->
                    <ColumnDefinition Width="*"/>     <!-- Search -->
                    <ColumnDefinition Width="Auto"/>  <!-- Sort -->
                    <ColumnDefinition Width="Auto"/>  <!-- Refresh -->
                    <ColumnDefinition Width="Auto"/>  <!-- Settings -->
                </Grid.ColumnDefinitions>

                <!-- Source filter -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Source:" Foreground="{DynamicResource TextLabel}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="SourceFilterCombo" Width="110"
                              Background="{DynamicResource InputBg}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource InputBorder}"
                              SelectionChanged="SourceFilterCombo_SelectionChanged">
                        <ComboBoxItem Content="All" IsSelected="True"/>
                        <ComboBoxItem Content="Pixfizz"/>
                        <ComboBoxItem Content="Dakis"/>
                    </ComboBox>
                </StackPanel>

                <!-- Search box -->
                <Border Grid.Column="1" Background="{DynamicResource SearchBg}"
                        BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                        CornerRadius="3" Padding="6,2" Margin="0,0,12,0">
                    <TextBox x:Name="SearchBox" Background="Transparent"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderThickness="0"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Search orders..." Foreground="#666666"
                                                                   FontStyle="Italic" Margin="2,0,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>

                <!-- Sort -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Sort:" Foreground="{DynamicResource TextLabel}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="SortCombo" Width="130"
                              Background="{DynamicResource InputBg}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource InputBorder}"
                              SelectionChanged="SortCombo_SelectionChanged">
                        <ComboBoxItem Content="Date Received" IsSelected="True"/>
                        <ComboBoxItem Content="Customer Name"/>
                        <ComboBoxItem Content="Order ID"/>
                    </ComboBox>
                </StackPanel>

                <!-- Refresh -->
                <Button Grid.Column="3" Content="Refresh" Margin="0,0,8,0"
                        Click="RefreshButton_Click"/>

                <!-- Settings -->
                <Button Grid.Column="4" Content="Settings"
                        Click="SettingsButton_Click"/>
            </Grid>
        </Border>

        <!-- ═══ Main content: Tabs + Detail panel ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>       <!-- Tree -->
                <ColumnDefinition Width="5"/>                      <!-- Splitter -->
                <ColumnDefinition Width="350" MinWidth="250"/>     <!-- Detail panel -->
            </Grid.ColumnDefinitions>

            <!-- Tab control with 3 tabs -->
            <TabControl x:Name="MainTabs" Grid.Column="0"
                        Background="Transparent"
                        BorderBrush="{DynamicResource BorderBrush}"
                        Foreground="{DynamicResource TextPrimary}"
                        SelectionChanged="MainTabs_SelectionChanged">

                <!-- Tab 1: Pending Orders -->
                <TabItem Header="Pending" Foreground="{DynamicResource TextPrimary}">
                    <TreeView x:Name="PendingTree"
                              Background="{DynamicResource TreeBg}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderThickness="0"
                              Padding="4"
                              SelectedItemChanged="PendingTree_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Sizes}">
                                <!-- Order node -->
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <!-- Source badge -->
                                    <Border CornerRadius="2" Padding="4,1" Margin="0,0,6,0"
                                            Background="{DynamicResource AccentBlue}"
                                            Visibility="{Binding SourceCode, Converter={x:Static local:StringToVisibilityConverter.Instance}}">
                                        <TextBlock Text="{Binding SourceLabel}"
                                                   Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <!-- Order label -->
                                    <TextBlock Text="{Binding DisplayLabel}"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="14" VerticalAlignment="Center"/>
                                    <!-- Date -->
                                    <TextBlock Text="{Binding DateLabel}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    <!-- Image count -->
                                    <TextBlock Foreground="{DynamicResource TextMuted}"
                                               FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} images">
                                                <Binding Path="TotalImages"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <!-- Held indicator -->
                                    <TextBlock Text=" HELD" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentOrange}"
                                               Visibility="{Binding IsHeld, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"
                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    <!-- Missing files indicator -->
                                    <TextBlock Text=" MISSING FILES" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentRed}"
                                               Visibility="{Binding HasMissingFiles, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"
                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                                <!-- Size child template -->
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <TextBlock Text="{Binding DisplayLabel}"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding CountLabel}"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <TextBlock Text="{Binding ChannelLabel}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <TextBlock Text="{Binding MissingLabel}"
                                                       Foreground="{DynamicResource AccentRed}"
                                                       FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"
                                                       Visibility="{Binding HasMissing, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </TabItem>

                <!-- Tab 2: Printed Orders -->
                <TabItem Header="Printed" Foreground="{DynamicResource TextPrimary}">
                    <TreeView x:Name="PrintedTree"
                              Background="{DynamicResource TreeBg}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderThickness="0"
                              Padding="4"
                              SelectedItemChanged="PrintedTree_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Sizes}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <Border CornerRadius="2" Padding="4,1" Margin="0,0,6,0"
                                            Background="{DynamicResource AccentBlue}">
                                        <TextBlock Text="{Binding SourceLabel}"
                                                   Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="{Binding DisplayLabel}"
                                               Foreground="{DynamicResource PrintedText}"
                                               FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DateLabel}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding StatusCode}"
                                               Foreground="{DynamicResource AccentGreen}"
                                               FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <TextBlock Text="{Binding DisplayLabel}"
                                                       Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                            <TextBlock Text="{Binding CountLabel}"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="11" Margin="8,0,0,0"/>
                                            <TextBlock Text="{Binding PrintedLabel}"
                                                       Foreground="{DynamicResource PrintedText}"
                                                       FontSize="11" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </TabItem>

                <!-- Tab 3: Other Store -->
                <TabItem Header="Other Store" Foreground="{DynamicResource TextPrimary}">
                    <TreeView x:Name="OtherStoreTree"
                              Background="{DynamicResource TreeBg}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderThickness="0"
                              Padding="4"
                              SelectedItemChanged="OtherStoreTree_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Sizes}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <Border CornerRadius="2" Padding="4,1" Margin="0,0,6,0"
                                            Background="{DynamicResource AccentBlue}">
                                        <TextBlock Text="{Binding SourceLabel}"
                                                   Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="{Binding DisplayLabel}"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding StoreName}"
                                               Foreground="{DynamicResource AccentOrange}"
                                               FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding DateLabel}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    <TextBlock Text=" HELD" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentOrange}"
                                               Visibility="{Binding IsHeld, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"
                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <TextBlock Text="{Binding DisplayLabel}"
                                                       Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                            <TextBlock Text="{Binding CountLabel}"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="11" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </TabItem>
            </TabControl>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource SplitterBg}"/>

            <!-- ═══ Detail Panel ═══ -->
            <Border Grid.Column="2" Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                    <StackPanel x:Name="DetailPanel">
                        <!-- Empty state -->
                        <TextBlock x:Name="DetailEmpty" Text="Select an order to view details"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontStyle="Italic" Margin="0,20,0,0"
                                   HorizontalAlignment="Center"/>

                        <!-- Order details (hidden until selection) -->
                        <StackPanel x:Name="DetailContent" Visibility="Collapsed">
                            <!-- Order ID -->
                            <TextBlock x:Name="DetailOrderId"
                                       Foreground="{DynamicResource TextHeading}"
                                       FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <!-- Status -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Status: " Foreground="{DynamicResource TextLabel}"/>
                                <TextBlock x:Name="DetailStatus" Foreground="{DynamicResource AccentGreen}"/>
                            </StackPanel>

                            <!-- Source -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Source: " Foreground="{DynamicResource TextLabel}"/>
                                <TextBlock x:Name="DetailSource" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>

                            <!-- Store -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Store: " Foreground="{DynamicResource TextLabel}"/>
                                <TextBlock x:Name="DetailStore" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>

                            <Border Height="1" Background="{DynamicResource SeparatorBg}" Margin="0,8"/>

                            <!-- Customer info -->
                            <TextBlock Text="Customer" Foreground="{DynamicResource TextHeading}"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,4,0,4"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="Name: " Foreground="{DynamicResource TextLabel}"/>
                                <TextBlock x:Name="DetailCustomerName" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="Email: " Foreground="{DynamicResource TextLabel}"/>
                                <TextBlock x:Name="DetailEmail" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="Phone: " Foreground="{DynamicResource TextLabel}"/>
                                <TextBlock x:Name="DetailPhone" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>

                            <Border Height="1" Background="{DynamicResource SeparatorBg}" Margin="0,8"/>

                            <!-- Order info -->
                            <TextBlock Text="Order Info" Foreground="{DynamicResource TextHeading}"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,4,0,4"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="Ordered: " Foreground="{DynamicResource TextLabel}"/>
                                <TextBlock x:Name="DetailOrderedAt" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="Total: " Foreground="{DynamicResource TextLabel}"/>
                                <TextBlock x:Name="DetailTotal" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="Items: " Foreground="{DynamicResource TextLabel}"/>
                                <TextBlock x:Name="DetailItemCount" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="Folder: " Foreground="{DynamicResource TextLabel}"/>
                                <TextBlock x:Name="DetailFolder" Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap" MaxWidth="280"/>
                            </StackPanel>

                            <!-- Special instructions -->
                            <StackPanel x:Name="DetailInstructionsPanel" Margin="0,4,0,0" Visibility="Collapsed">
                                <TextBlock Text="Instructions:" Foreground="{DynamicResource TextLabel}"/>
                                <TextBlock x:Name="DetailInstructions"
                                           Foreground="{DynamicResource AccentOrange}"
                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>

                            <Border Height="1" Background="{DynamicResource SeparatorBg}" Margin="0,8"/>

                            <!-- Size detail (shown when a size node is selected) -->
                            <StackPanel x:Name="SizeDetailPanel" Visibility="Collapsed">
                                <TextBlock Text="Size Detail" Foreground="{DynamicResource TextHeading}"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                <TextBlock x:Name="SizeDetailLabel" Foreground="{DynamicResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock x:Name="SizeDetailChannel" Foreground="{DynamicResource TextSecondary}"
                                           Margin="0,0,0,4"/>

                                <!-- Image list -->
                                <TextBlock Text="Images:" Foreground="{DynamicResource TextLabel}" Margin="0,4,0,2"/>
                                <ListBox x:Name="SizeImageList"
                                         Background="{DynamicResource SurfaceBg}"
                                         Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         MaxHeight="300">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="2">
                                                <TextBlock Text="{Binding ImageFilename}"
                                                           Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                                                <TextBlock Text="{Binding Quantity, StringFormat=' x{0}'}"
                                                           Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                                           Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border Height="1" Background="{DynamicResource SeparatorBg}" Margin="0,8"/>
                            </StackPanel>

                            <!-- Notes -->
                            <TextBlock Text="Notes" Foreground="{DynamicResource TextHeading}"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,4,0,4"/>
                            <ListBox x:Name="NotesListBox"
                                     Background="{DynamicResource SurfaceBg}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     MaxHeight="200">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:MM/dd HH:mm}'}"
                                                           Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                <TextBlock Text="{Binding EmployeeName}"
                                                           Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                                           Margin="8,0,0,0"/>
                                                <TextBlock Text="{Binding NoteType, StringFormat='[{0}]'}"
                                                           Foreground="{DynamicResource TextMuted}" FontSize="10"
                                                           Margin="8,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding NoteText}"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       TextWrapping="Wrap" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Channel assignment (visible when size selected) -->
                            <StackPanel x:Name="ChannelAssignPanel" Visibility="Collapsed">
                                <TextBlock Text="Assign Channel" Foreground="{DynamicResource TextHeading}"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="ChannelCombo" Grid.Column="0"
                                              Background="{DynamicResource InputBg}"
                                              Foreground="{DynamicResource TextPrimary}"
                                              BorderBrush="{DynamicResource InputBorder}"
                                              IsEditable="True"/>
                                    <Button Grid.Column="1" Content="Assign" Margin="6,0,0,0"
                                            Click="AssignChannelButton_Click"/>
                                </Grid>
                                <Border Height="1" Background="{DynamicResource SeparatorBg}" Margin="0,8"/>
                            </StackPanel>

                            <!-- Action buttons -->
                            <Border Height="1" Background="{DynamicResource SeparatorBg}" Margin="0,8"/>
                            <WrapPanel Margin="0,4,0,0">
                                <Button Content="Print Selected" Margin="0,0,6,6"
                                        Background="{DynamicResource ButtonPrintBg}"
                                        Click="PrintSelectedButton_Click"/>
                                <Button Content="Color Correct" Margin="0,0,6,6"
                                        Click="ColorCorrectButton_Click"/>
                                <Button Content="Change Size" Margin="0,0,6,6"
                                        Click="ChangeSizeButton_Click"/>
                                <Button Content="Notify" Margin="0,0,6,6"
                                        Click="NotifyButton_Click"/>
                                <Button Content="Hold / Release" Margin="0,0,6,6"
                                        Click="HoldButton_Click"/>
                                <Button Content="Transfer" Margin="0,0,6,6"
                                        Click="TransferButton_Click"/>
                                <Button Content="Open Folder" Margin="0,0,6,6"
                                        Click="OpenFolderButton_Click"/>
                            </WrapPanel>

                            <!-- Thumbnail strip -->
                            <Border Height="1" Background="{DynamicResource SeparatorBg}" Margin="0,8"/>
                            <TextBlock Text="Thumbnails" Foreground="{DynamicResource TextHeading}"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,4,0,4"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                          MaxHeight="140">
                                <WrapPanel x:Name="ThumbnailPanel" Orientation="Horizontal"/>
                            </ScrollViewer>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══ Status bar ═══ -->
        <Border Grid.Row="2" Background="{DynamicResource ToolbarBg}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- DB status -->
                    <ColumnDefinition Width="*"/>     <!-- Order counts -->
                    <ColumnDefinition Width="Auto"/>  <!-- Alert indicator -->
                    <ColumnDefinition Width="Auto"/>  <!-- Dev mode -->
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse x:Name="DbStatusDot" Width="8" Height="8" Margin="0,0,6,0"/>
                    <TextBlock x:Name="DbStatusText" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                </StackPanel>

                <TextBlock x:Name="OrderCountText" Grid.Column="1"
                           Foreground="{DynamicResource TextSecondary}" FontSize="11"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0">
                    <TextBlock x:Name="AlertCountText" Foreground="{DynamicResource AccentOrange}"
                               FontSize="11" VerticalAlignment="Center" Cursor="Hand"
                               MouseLeftButtonUp="AlertCountText_Click"/>
                </StackPanel>

                <TextBlock x:Name="DevModeText" Grid.Column="3"
                           Text="DEV MODE" Foreground="{DynamicResource AccentRed}"
                           FontWeight="Bold" FontSize="11"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Window>
