<Window x:Class="HitePhoto.PrintStation.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        xmlns:vm="clr-namespace:HitePhoto.PrintStation.UI.ViewModels"
        xmlns:local="clr-namespace:HitePhoto.PrintStation.UI"
        Title="HitePhoto Print Station"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="550"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}">

    <Window.Resources>
        <ResourceDictionary>

        <local:StoreColorConverter x:Key="StoreColorConverter"/>

        <!-- ── Font settings (overridden from AppSettings in code-behind) ── -->
        <system:Double x:Key="OrderFontSize">14</system:Double>
        <system:Double x:Key="SizeFontSize">13</system:Double>
        <FontFamily x:Key="TreeFontFamily">Segoe UI</FontFamily>

        <!-- ── TreeView styles (ported from PrintRouter) ── -->
        <Style TargetType="TreeView">
            <Setter Property="Background"      Value="{DynamicResource TreeBg}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding"     Value="2,2"/>
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="Expander" Grid.Column="0"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              ClickMode="Press" Focusable="False"
                                              Width="16" Height="16" VerticalAlignment="Center">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <TextBlock x:Name="ArrowText" Text="▶"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           FontSize="8" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="ArrowText" Property="Text" Value="▼"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Border x:Name="Bd" Grid.Column="1"
                                        Background="Transparent"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter x:Name="PART_Header"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Stretch"/>
                                </Border>
                            </Grid>
                            <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Margin="20,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource TreeSelection}"/>
                            </DataTrigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource SeparatorBg}"/>
            <Setter Property="Margin"     Value="0,6"/>
        </Style>

        <!-- ── Order node template ── -->
        <HierarchicalDataTemplate DataType="{x:Type vm:OrderTreeItem}"
                                  ItemsSource="{Binding TreeChildren}">
            <Border x:Name="SelectionBorder" Background="{Binding RowBackground}"
                    CornerRadius="3" Padding="2,0" Margin="0,8,4,1">
                <Border.ContextMenu>
                    <ContextMenu Opened="OrderContextMenu_Opened">
                        <MenuItem x:Name="CtxPrint" Header="Print" Click="ContextMenu_Print_Click"/>
                        <MenuItem x:Name="CtxPrintEmail" Header="Print &amp; Email" Click="ContextMenu_PrintAndEmail_Click"/>
                        <MenuItem x:Name="CtxEmail" Header="Email" Click="ContextMenu_Email_Click"/>
                        <Separator x:Name="CtxPrintSep"/>
                        <MenuItem x:Name="CtxMarkPrinted" Header="Mark Printed" Click="ContextMenu_MarkPrinted_Click"/>
                        <MenuItem x:Name="CtxMarkUnprinted" Header="Mark Unprinted" Click="ContextMenu_MarkUnprinted_Click"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="NameText"
                               Text="{Binding DisplayLabel}"
                               Foreground="{Binding StoreName, Converter={StaticResource StoreColorConverter}}"
                               FontSize="{DynamicResource OrderFontSize}" FontWeight="Bold"
                               FontFamily="{DynamicResource TreeFontFamily}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="SrcTag"
                               Text="{Binding StoreName}"
                               Foreground="{Binding StoreName, Converter={StaticResource StoreColorConverter}}"
                               FontSize="9" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock x:Name="FromTag"
                               Text="{Binding StoreTag}"
                               Foreground="#FF9800" FontSize="10" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock x:Name="HoldBadge" Text=" HOLD"
                               Foreground="White" FontSize="10" FontWeight="Bold"
                               VerticalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>
            </Border>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsParentOrder}" Value="True">
                    <Setter TargetName="NameText" Property="Foreground" Value="{DynamicResource ParentBrown}"/>
                    <Setter TargetName="NameText" Property="FontSize" Value="12"/>
                    <Setter TargetName="NameText" Property="FontWeight" Value="Normal"/>
                    <Setter TargetName="SrcTag" Property="Foreground" Value="{DynamicResource ParentBrown}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsUnnotifiedPrinted}" Value="True">
                    <Setter TargetName="NameText" Property="Foreground" Value="{DynamicResource AccentOrange}"/>
                    <Setter TargetName="SrcTag" Property="Foreground" Value="{DynamicResource AccentOrange}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsHeld}" Value="True">
                    <Setter TargetName="SelectionBorder" Property="Background" Value="#D32F2F"/>
                    <Setter TargetName="NameText" Property="Foreground" Value="White"/>
                    <Setter TargetName="HoldBadge" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="FromTag" Property="Foreground" Value="#FFCDD2"/>
                    <Setter TargetName="SrcTag" Property="Foreground" Value="#FFCDD2"/>
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>

        <!-- ── Size node template ── -->
        <DataTemplate DataType="{x:Type vm:SizeTreeItem}">
            <StackPanel Orientation="Horizontal" Margin="2,0,4,0">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Print" Click="SizeContextMenu_Print_Click"/>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <TextBlock x:Name="SzText"
                           Text="{Binding DisplayLabel}"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="{DynamicResource SizeFontSize}"
                           FontFamily="{DynamicResource TreeFontFamily}"/>
                <TextBlock Text="{Binding CountLabel}"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ChannelLabel}"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="MissingText"
                           Text="{Binding MissingLabel}"
                           Foreground="{DynamicResource AccentRed}"
                           FontSize="11" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsParentSize}" Value="True">
                    <Setter TargetName="SzText" Property="Foreground" Value="{DynamicResource ParentBrown}"/>
                    <Setter TargetName="SzText" Property="FontSize" Value="11"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsUnmapped}" Value="True">
                    <Setter TargetName="SzText" Property="Foreground" Value="{DynamicResource TextMuted}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsPrinted}" Value="True">
                    <Setter TargetName="SzText" Property="Foreground" Value="{DynamicResource AccentGreen}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasMissing}" Value="True">
                    <Setter TargetName="MissingText" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource ToolbarBg}" Height="26" Padding="10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse x:Name="DbStatusDot" Width="8" Height="8" Margin="0,0,6,0"/>
                    <TextBlock x:Name="DbStatusText" Foreground="{DynamicResource TextSecondary}" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="OrderCountText" Grid.Column="1"
                           VerticalAlignment="Center" FontSize="11"
                           Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"/>
                <Border x:Name="AlertBadge" Grid.Column="2" Background="{DynamicResource AccentRed}"
                        CornerRadius="8" Padding="6,1" Margin="0,0,8,0" Cursor="Hand"
                        MouseDown="AlertBadge_Click" Visibility="Collapsed"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="AlertBadgeText" Text="0" Foreground="White"
                               FontSize="10" FontWeight="Bold"/>
                </Border>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="DevModeText"
                               Text="DEV MODE" Foreground="{DynamicResource AccentRed}"
                               FontWeight="Bold" FontSize="11" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="TestModeText"
                               Text="TEST MODE" Foreground="{DynamicResource AccentRed}"
                               FontWeight="Bold" FontSize="11" VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBg}" Padding="8,5">
            <StackPanel Orientation="Horizontal">
                <Button Content="Change Size" Width="100" Margin="0,0,6,0"
                        Click="ChangeSizeButton_Click"/>
                <Button Content="Open Folder" Width="100" Margin="0,0,6,0"
                        Click="OpenFolderButton_Click"/>
                <Button Content="Hold" Width="60" Margin="0,0,6,0"
                        Click="HoldButton_Click"/>
                <Button Content="Transfer" Width="80" Margin="0,0,6,0"
                        Click="TransferButton_Click"
                        Visibility="Collapsed"/>
                <Button x:Name="ProductionBtn" Content="Send" Width="100" Margin="0,0,6,0"
                        Click="ProductionButton_Click"/>
                <Button Content="Refresh" Width="80" Margin="0,0,6,0"
                        Click="RefreshButton_Click"/>
                <Button Content="Color Correct" Width="110" Margin="0,0,6,0"
                        Click="ColorCorrectButton_Click"/>
                <Button Content="Settings" Width="80"
                        Click="SettingsButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Filter/Sort strip -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,4,4,0" VerticalAlignment="Center">
                <CheckBox x:Name="ExpandAllCheck" Content="Expand all" IsChecked="True"
                          VerticalAlignment="Center"
                          Checked="ExpandAll_Changed" Unchecked="ExpandAll_Changed"/>

                <TextBlock Text="Source:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" Margin="20,0,4,0" FontSize="11"/>
                <ComboBox x:Name="SourceFilterCombo" Width="100" FontSize="11"
                          VerticalAlignment="Center"
                          SelectionChanged="SourceFilterCombo_SelectionChanged">
                    <ComboBoxItem Content="All" IsSelected="True"/>
                    <ComboBoxItem Content="Dakis"/>
                    <ComboBoxItem Content="Pixfizz"/>
                </ComboBox>

                <TextBlock Text="Sort:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" Margin="12,0,4,0" FontSize="11"/>
                <ComboBox x:Name="SortCombo" Width="120" FontSize="11"
                          VerticalAlignment="Center"
                          SelectionChanged="SortCombo_SelectionChanged">
                    <ComboBoxItem Content="Date Ordered" IsSelected="True"/>
                    <ComboBoxItem Content="Date Printed"/>
                    <ComboBoxItem Content="Customer Name"/>
                    <ComboBoxItem Content="Order ID"/>
                </ComboBox>

                <TextBlock Text="Search:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" Margin="12,0,4,0" FontSize="11"/>
                <TextBox x:Name="SearchBox" Width="200" FontSize="11"
                         VerticalAlignment="Center" Padding="4,3"
                         TextChanged="SearchBox_TextChanged"/>
                <Button Content="X" Width="22" Height="22" Margin="2,0,0,0"
                        FontSize="10" Padding="0" VerticalAlignment="Center"
                        Click="ClearSearch_Click"/>
            </StackPanel>

            <!-- Tabs + shared detail pane -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380" MinWidth="220"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition MinWidth="300"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Tab trees -->
                <TabControl Grid.Column="0" x:Name="MainTabs" Background="{DynamicResource WindowBg}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            SelectionChanged="MainTabs_SelectionChanged">

                    <TabItem x:Name="PendingTab" Header="Pending Orders">
                        <TreeView x:Name="PendingTree"
                                  PreviewMouseLeftButtonDown="Tree_PreviewMouseDown"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"/>
                    </TabItem>

                    <TabItem x:Name="PrintedTab" Header="Printed Orders">
                        <TreeView x:Name="PrintedTree"
                                  PreviewMouseLeftButtonDown="Tree_PreviewMouseDown"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"/>
                    </TabItem>

                    <TabItem x:Name="OtherStoreTab">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="OtherStoreLabel" Text="Other Store" VerticalAlignment="Center"/>
                                <CheckBox x:Name="PickupHereCheck" VerticalAlignment="Center"
                                          Margin="8,0,0,0"
                                          Checked="PickupHereCheck_Changed"
                                          Unchecked="PickupHereCheck_Changed"/>
                            </StackPanel>
                        </TabItem.Header>
                        <TreeView x:Name="OtherStoreTree"
                                  PreviewMouseLeftButtonDown="Tree_PreviewMouseDown"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"/>
                    </TabItem>

                </TabControl>

                <GridSplitter Grid.Column="1" Width="5"
                              HorizontalAlignment="Stretch" Background="{DynamicResource SplitterBg}"/>

                <!-- Right: Shared detail pane (visible on all tabs) -->
                <Grid Grid.Column="2" Background="{DynamicResource PanelBg}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="DetailEmpty" Grid.RowSpan="6"
                               Text="Select an order or size"
                               Foreground="{DynamicResource TextMuted}" FontSize="13"
                               FontStyle="Italic"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <StackPanel x:Name="DetailContent" Grid.Row="0" Visibility="Collapsed" Margin="10,8,10,0">
                        <!-- Line 1: Order ID, Customer Name, Phone -->
                        <WrapPanel Orientation="Horizontal">
                            <TextBlock x:Name="DetailOrderId" FontSize="36"
                                       FontWeight="SemiBold" Foreground="{DynamicResource TextHeading}"
                                       VerticalAlignment="Center" Margin="0,0,20,0"/>
                            <TextBlock x:Name="DetailCustomerName" FontSize="32"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center" Margin="0,0,20,0"/>
                            <TextBlock x:Name="DetailPhone" FontSize="28"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="DetailEmail" FontSize="24"
                                       Foreground="{DynamicResource TextMuted}"
                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </WrapPanel>
                        <!-- Line 2: Status, Source, Store, Date, Items -->
                        <WrapPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="Status:" Foreground="{DynamicResource TextLabel}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock x:Name="DetailStatus" Foreground="{DynamicResource AccentGreen}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Source:" Foreground="{DynamicResource TextLabel}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock x:Name="DetailSource" Foreground="{DynamicResource TextPrimary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Store:" Foreground="{DynamicResource TextLabel}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock x:Name="DetailStore" Foreground="{DynamicResource TextPrimary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Ordered:" Foreground="{DynamicResource TextLabel}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock x:Name="DetailOrderedAt" Foreground="{DynamicResource TextPrimary}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Items:" Foreground="{DynamicResource TextLabel}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock x:Name="DetailItemCount" Foreground="{DynamicResource TextPrimary}" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Size detail + channel assignment -->
                    <StackPanel x:Name="SizeDetailPanel" Grid.Row="1" Visibility="Collapsed" Margin="10,6,10,0">
                        <WrapPanel Orientation="Horizontal">
                            <TextBlock x:Name="SizeDetailLabel" FontSize="28"
                                       FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock x:Name="SizeDetailChannel" FontSize="24"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <Grid Width="200" Margin="0,0,6,0" VerticalAlignment="Center">
                                <TextBox x:Name="ChannelSearchBox" Padding="4,3" FontSize="11"
                                         Background="Transparent"
                                         TextChanged="ChannelSearch_TextChanged"
                                         GotFocus="ChannelSearchBox_GotFocus"/>
                                <TextBlock x:Name="ChannelSearchPlaceholder"
                                           Text="Search channels..." FontSize="11" Padding="6,4"
                                           Foreground="{DynamicResource TextMuted}"
                                           IsHitTestVisible="False"/>
                            </Grid>
                            <Button x:Name="AssignChannelBtn" Content="Assign" Width="70" FontSize="11"
                                    VerticalAlignment="Center"
                                    Click="AssignChannel_Click"/>
                        </WrapPanel>
                    </StackPanel>
                    <Popup x:Name="ChannelPopup"
                           PlacementTarget="{Binding ElementName=ChannelSearchBox}"
                           Placement="Bottom"
                           StaysOpen="True"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="{DynamicResource InputBg}"
                                BorderBrush="{DynamicResource InputBorder}"
                                BorderThickness="1">
                            <ListBox x:Name="ChannelList" MaxHeight="280" MinWidth="300"
                                     Background="{DynamicResource InputBg}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     FontSize="11" BorderThickness="0"
                                     MouseLeftButtonUp="ChannelList_MouseClick"/>
                        </Border>
                    </Popup>

                    <!-- Order options (Glossy, Matte, etc.) -->
                    <StackPanel x:Name="OptionsPanel" Grid.Row="2" Visibility="Collapsed" Margin="10,4,10,0">
                        <ItemsControl x:Name="OptionsList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="6,2" Margin="0,0,4,2"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Click="OptionBadge_ToggleDefault_Click">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Header" Value="Set as Default"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                                    <Setter Property="Header" Value="Remove Default"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <TextBlock Text="{Binding DisplayText}" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Notes (last 2 + History button) -->
                    <StackPanel Grid.Row="3" Margin="10,4,10,0">
                        <ItemsControl x:Name="NotesPreview">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,1">
                                        <TextBlock Text="{Binding CreatedAt}"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="10"/>
                                        <TextBlock Text="{Binding Note}"
                                                   Foreground="{DynamicResource TextPrimary}" FontSize="11"
                                                   Margin="8,0,0,0" TextWrapping="NoWrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button x:Name="HistoryButton" Content="History..."
                                HorizontalAlignment="Left" Padding="6,2" Margin="0,2,0,0"
                                FontSize="10" Visibility="Collapsed"
                                Click="HistoryButton_Click"/>
                    </StackPanel>

                    <!-- Thumbnail strip (pinned to bottom) -->
                    <Border Grid.Row="5" Background="{DynamicResource WindowBg}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <WrapPanel x:Name="ThumbnailPanel" Orientation="Horizontal" Margin="6,4"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <!-- Alert Panel -->
            <Border Grid.Row="2" x:Name="AlertPanel"
                    Background="{DynamicResource AlertPanelBg}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Visibility="Collapsed"
                    MaxHeight="200">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBg}" Padding="8,4">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock x:Name="AlertHeaderText" Text="Alerts (0)"
                                           FontWeight="SemiBold" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Dismiss All" FontSize="11" Padding="8,2"
                                        Click="DismissAllAlerts_Click"/>
                                <Button Content="Hide" FontSize="11" Padding="8,2" Margin="4,0,0,0"
                                        Click="CollapseAlertPanel_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="AlertList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4" Margin="0,0,0,1"
                                            Background="{Binding BackgroundBrush}">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="X" FontSize="10"
                                                    Padding="4,1" VerticalAlignment="Top"
                                                    Click="DismissAlert_Click"
                                                    Tag="{Binding Id}"/>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding SeverityLabel}"
                                                               FontWeight="Bold" FontSize="11"
                                                               Foreground="{Binding SeverityBrush}"/>
                                                    <TextBlock Text="{Binding TimestampText}"
                                                               Foreground="{DynamicResource TextMuted}"
                                                               FontSize="11" Margin="8,0,0,0"/>
                                                    <TextBlock Text="{Binding OrderId}"
                                                               Foreground="{DynamicResource AccentBlue}"
                                                               FontSize="11" Margin="8,0,0,0"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Summary}"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           FontSize="12" TextWrapping="Wrap"/>
                                                <Expander Header="Technical Detail" FontSize="10"
                                                          Foreground="{DynamicResource TextMuted}"
                                                          IsExpanded="{Binding IsDetailExpanded}">
                                                    <TextBlock Text="{Binding TechnicalDetail}"
                                                               FontFamily="Consolas" FontSize="10"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                </Expander>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>
