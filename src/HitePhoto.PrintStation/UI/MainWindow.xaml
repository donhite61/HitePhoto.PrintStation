<Window x:Class="HitePhoto.PrintStation.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        xmlns:vm="clr-namespace:HitePhoto.PrintStation.UI.ViewModels"
        Title="HitePhoto Print Station"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="550"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}">

    <Window.Resources>
        <ResourceDictionary>

        <!-- ── TreeView styles (ported from PrintRouter) ── -->
        <Style TargetType="TreeView">
            <Setter Property="Background"      Value="{DynamicResource TreeBg}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding"     Value="2,2"/>
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="Expander" Grid.Column="0"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              ClickMode="Press" Focusable="False"
                                              Width="16" Height="16" VerticalAlignment="Center">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <TextBlock x:Name="ArrowText" Text="▶"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           FontSize="8" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="ArrowText" Property="Text" Value="▼"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Border x:Name="Bd" Grid.Column="1"
                                        Background="Transparent"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter x:Name="PART_Header"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Stretch"/>
                                </Border>
                            </Grid>
                            <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Margin="20,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource TreeSelection}"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource SeparatorBg}"/>
            <Setter Property="Margin"     Value="0,6"/>
        </Style>

        <!-- ── Order node template ── -->
        <HierarchicalDataTemplate DataType="{x:Type vm:OrderTreeItem}"
                                  ItemsSource="{Binding Sizes}">
            <Border x:Name="SelectionBorder" Background="Transparent"
                    CornerRadius="3" Padding="2,0" Margin="0,8,4,1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="NameText"
                               Text="{Binding DisplayLabel}"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="SrcTag"
                               Text="{Binding SourceLabel}"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="9" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock x:Name="HoldBadge" Text=" HOLD"
                               Foreground="#FF9800" FontSize="10" FontWeight="Bold"
                               VerticalAlignment="Center" Visibility="Collapsed"/>
                    <TextBlock x:Name="MissingBadge" Text=" MISSING FILES"
                               Foreground="{DynamicResource AccentRed}" FontSize="10" FontWeight="Bold"
                               VerticalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>
            </Border>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsHeld}" Value="True">
                    <Setter TargetName="HoldBadge" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="NameText" Property="Foreground" Value="{DynamicResource AccentRed}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasMissingFiles}" Value="True">
                    <Setter TargetName="MissingBadge" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>

        <!-- ── Size node template ── -->
        <DataTemplate DataType="{x:Type vm:SizeTreeItem}">
            <StackPanel Orientation="Horizontal" Margin="2,0,4,0">
                <TextBlock x:Name="SzText"
                           Text="{Binding DisplayLabel}"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="13"/>
                <TextBlock Text="{Binding CountLabel}"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ChannelLabel}"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsPrinted}" Value="True">
                    <Setter TargetName="SzText" Property="Foreground" Value="{DynamicResource AccentGreen}"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource ToolbarBg}" Height="26" Padding="10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse x:Name="DbStatusDot" Width="8" Height="8" Margin="0,0,6,0"/>
                    <TextBlock x:Name="DbStatusText" Foreground="{DynamicResource TextSecondary}" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="OrderCountText" Grid.Column="1"
                           VerticalAlignment="Center" FontSize="11"
                           Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="DevModeText" Grid.Column="2"
                           Text="DEV MODE" Foreground="{DynamicResource AccentRed}"
                           FontWeight="Bold" FontSize="11" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBg}" Padding="8,5">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PrintBtn" Content="Print Selected"
                        Width="120" Margin="0,0,6,0" Background="{DynamicResource ButtonPrintBg}"
                        Click="PrintSelectedButton_Click"/>
                <Button Content="Change Size" Width="100" Margin="0,0,6,0"
                        Click="ChangeSizeButton_Click"/>
                <Button Content="Refresh" Width="80" Margin="0,0,6,0"
                        Click="RefreshButton_Click"/>
                <Button Content="Open Folder" Width="100" Margin="0,0,6,0"
                        Click="OpenFolderButton_Click"/>
                <Button Content="Color Correct" Width="110" Margin="0,0,6,0"
                        Click="ColorCorrectButton_Click"/>
                <Button Content="Hold / Release" Width="100" Margin="0,0,6,0"
                        Click="HoldButton_Click"/>
                <Button Content="Notify" Width="70" Margin="0,0,6,0"
                        Click="NotifyButton_Click"/>
                <Button Content="Transfer" Width="80" Margin="0,0,16,0"
                        Click="TransferButton_Click"/>
                <Button Content="Settings" Width="80"
                        Click="SettingsButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filter/Sort strip -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,4,4,0" VerticalAlignment="Center">
                <CheckBox x:Name="ExpandAllCheck" Content="Expand all" IsChecked="True"
                          VerticalAlignment="Center"
                          Checked="ExpandAll_Changed" Unchecked="ExpandAll_Changed"/>

                <TextBlock Text="Source:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" Margin="20,0,4,0" FontSize="11"/>
                <ComboBox x:Name="SourceFilterCombo" Width="100" FontSize="11"
                          VerticalAlignment="Center"
                          SelectionChanged="SourceFilterCombo_SelectionChanged">
                    <ComboBoxItem Content="All" IsSelected="True"/>
                    <ComboBoxItem Content="Dakis"/>
                    <ComboBoxItem Content="Pixfizz"/>
                </ComboBox>

                <TextBlock Text="Sort:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" Margin="12,0,4,0" FontSize="11"/>
                <ComboBox x:Name="SortCombo" Width="120" FontSize="11"
                          VerticalAlignment="Center"
                          SelectionChanged="SortCombo_SelectionChanged">
                    <ComboBoxItem Content="Date Received" IsSelected="True"/>
                    <ComboBoxItem Content="Customer Name"/>
                    <ComboBoxItem Content="Order ID"/>
                </ComboBox>

                <TextBlock Text="Search:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" Margin="12,0,4,0" FontSize="11"/>
                <TextBox x:Name="SearchBox" Width="200" FontSize="11"
                         VerticalAlignment="Center" Padding="4,3"
                         TextChanged="SearchBox_TextChanged"/>
            </StackPanel>

            <!-- Tabs -->
            <TabControl Grid.Row="1" x:Name="MainTabs" Background="{DynamicResource WindowBg}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        SelectionChanged="MainTabs_SelectionChanged">

                <!-- PENDING -->
                <TabItem Header="Pending Orders">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="380" MinWidth="220"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition MinWidth="300"/>
                        </Grid.ColumnDefinitions>

                        <TreeView Grid.Column="0" x:Name="PendingTree"
                                  SelectedItemChanged="PendingTree_SelectedItemChanged"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"/>

                        <GridSplitter Grid.Column="1" Width="5"
                                      HorizontalAlignment="Stretch" Background="{DynamicResource SplitterBg}"/>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="130" MinHeight="80"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Background="{DynamicResource PanelBg}">
                                <StackPanel Margin="14,10">
                                    <TextBlock x:Name="DetailEmpty"
                                               Text="Select an order or size"
                                               Foreground="{DynamicResource TextMuted}" FontSize="13"
                                               FontStyle="Italic"
                                               HorizontalAlignment="Center" Margin="0,40,0,0"/>

                                    <StackPanel x:Name="DetailContent" Visibility="Collapsed">
                                        <TextBlock x:Name="DetailOrderId" FontSize="16"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource TextHeading}"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="Status: " Foreground="{DynamicResource TextLabel}"/>
                                            <TextBlock x:Name="DetailStatus" Foreground="{DynamicResource AccentGreen}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="Source: " Foreground="{DynamicResource TextLabel}"/>
                                            <TextBlock x:Name="DetailSource" Foreground="{DynamicResource TextPrimary}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="Store: " Foreground="{DynamicResource TextLabel}"/>
                                            <TextBlock x:Name="DetailStore" Foreground="{DynamicResource TextPrimary}"/>
                                        </StackPanel>
                                        <Separator/>

                                        <TextBlock Text="CUSTOMER" FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                                   FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="DetailCustomerName" FontSize="14"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock x:Name="DetailEmail" FontSize="12"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock x:Name="DetailPhone" FontSize="12"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <Separator/>

                                        <TextBlock Text="ORDER INFO" FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                                   FontWeight="Bold" Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock Text="Ordered: " Foreground="{DynamicResource TextLabel}"/>
                                            <TextBlock x:Name="DetailOrderedAt" Foreground="{DynamicResource TextPrimary}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock Text="Items: " Foreground="{DynamicResource TextLabel}"/>
                                            <TextBlock x:Name="DetailItemCount" Foreground="{DynamicResource TextPrimary}"/>
                                        </StackPanel>

                                        <!-- Size detail -->
                                        <StackPanel x:Name="SizeDetailPanel" Visibility="Collapsed">
                                            <Separator/>
                                            <TextBlock Text="SIZE DETAIL" FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                                       FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="SizeDetailLabel" FontSize="14"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock x:Name="SizeDetailChannel" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Notes -->
                                        <Separator/>
                                        <TextBlock Text="NOTES" FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                                   FontWeight="Bold" Margin="0,0,0,4"/>
                                        <ListBox x:Name="NotesListBox" MaxHeight="150"
                                                 Background="{DynamicResource SurfaceBg}"
                                                 BorderBrush="{DynamicResource BorderBrush}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="2">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:MM/dd HH:mm}'}"
                                                                       Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                            <TextBlock Text="{Binding EmployeeName}"
                                                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                                                       Margin="8,0,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding NoteText}"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   TextWrapping="Wrap" FontSize="12"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <GridSplitter Grid.Row="1" Height="5"
                                          HorizontalAlignment="Stretch" Background="{DynamicResource SplitterBg}"/>

                            <!-- Thumbnail strip -->
                            <Border Grid.Row="2" Background="{DynamicResource WindowBg}">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <WrapPanel x:Name="ThumbnailPanel" Orientation="Horizontal" Margin="6,4"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- PRINTED -->
                <TabItem Header="Printed Orders">
                    <TreeView x:Name="PrintedTree"
                              SelectedItemChanged="PrintedTree_SelectedItemChanged"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"/>
                </TabItem>

                <!-- OTHER STORE -->
                <TabItem Header="Other Store">
                    <TreeView x:Name="OtherStoreTree"
                              SelectedItemChanged="OtherStoreTree_SelectedItemChanged"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"/>
                </TabItem>

            </TabControl>
        </Grid>
    </DockPanel>
</Window>
