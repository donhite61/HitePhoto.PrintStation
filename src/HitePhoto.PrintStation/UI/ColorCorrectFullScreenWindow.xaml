<Window x:Class="HitePhoto.PrintStation.UI.ColorCorrectFullScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HitePhoto.PrintStation.UI.ViewModels"
        Title="Color Correction — Full Screen"
        WindowState="Maximized"
        Background="#B8B8B8"
        Foreground="#303030"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <vm:FileNameConverter x:Key="FileNameConv"/>
    </Window.Resources>

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#A0A0A0" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding State.ImagePath, Converter={StaticResource FileNameConv}}"
                               FontSize="13" Foreground="#505050"/>
                    <TextBlock Text="  ·  " Foreground="#888888" FontSize="13"/>
                    <TextBlock Text="{Binding DimensionLabel}" FontSize="12" Foreground="#707070"/>
                    <TextBlock Text=" · " Foreground="#888888" FontSize="12"/>
                    <TextBlock Text="{Binding ZoomLabel}" FontSize="12" Foreground="#606060"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Esc or Enter to return" FontSize="11"
                               Foreground="#707070" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="✓  Done  (Enter)" Background="#467846" Width="140"
                            Click="Done_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Correction values bar — corrections only, horizontal row -->
        <Border DockPanel.Dock="Bottom" Background="#9C9C9C" Padding="16,8">
            <ItemsControl ItemsSource="{Binding FullScreenSlots}" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,0" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Definition.Label}"
                                       FontSize="10"
                                       Foreground="{Binding Definition.LabelBrush}"
                                       HorizontalAlignment="Center"/>
                            <Border Background="{Binding CurrentValueBgBrush}"
                                    CornerRadius="2" Padding="4,2" MinWidth="40"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="Slot_LeftClick"
                                    MouseRightButtonDown="Slot_RightClick">
                                <TextBlock Text="{Binding DisplayValue}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{Binding CurrentValueFgBrush}"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Large image with crop overlay -->
        <Grid SizeChanged="FullImage_SizeChanged">
            <Image x:Name="FullImage"
                   Source="{Binding PreviewBitmap, NotifyOnTargetUpdated=True}"
                   Stretch="Uniform"
                   TargetUpdated="FullImage_BitmapUpdated"/>

            <Rectangle x:Name="FullCropRect"
                       Stroke="#FFD700" StrokeThickness="2"
                       Fill="Transparent" Visibility="Collapsed"
                       IsHitTestVisible="False"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"/>


            <!-- Rendering indicator -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="12" Background="#88FFFFFF" CornerRadius="4" Padding="8,4">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRendering}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Rendering…" FontSize="12" Foreground="#505050"/>
            </Border>
        </Grid>

    </DockPanel>
</Window>
