<Window x:Class="HitePhoto.PrintStation.UI.AlertHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alert History"
        Width="900" Height="600"
        MinWidth="600" MinHeight="400"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}">
    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBg}" Padding="8,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Severity:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,4,0"/>
                <ComboBox x:Name="SeverityFilter" Width="90" FontSize="11"
                          VerticalAlignment="Center" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="All" IsSelected="True"/>
                    <ComboBoxItem Content="ERROR"/>
                    <ComboBoxItem Content="WARN"/>
                </ComboBox>

                <TextBlock Text="Category:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="12,0,4,0"/>
                <ComboBox x:Name="CategoryFilter" Width="110" FontSize="11"
                          VerticalAlignment="Center" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="All" IsSelected="True"/>
                    <ComboBoxItem Content="Parsing"/>
                    <ComboBoxItem Content="DataQuality"/>
                    <ComboBoxItem Content="Printing"/>
                    <ComboBoxItem Content="Network"/>
                    <ComboBoxItem Content="Database"/>
                    <ComboBoxItem Content="Settings"/>
                    <ComboBoxItem Content="Update"/>
                    <ComboBoxItem Content="General"/>
                </ComboBox>

                <TextBlock Text="Days:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="12,0,4,0"/>
                <ComboBox x:Name="DaysFilter" Width="60" FontSize="11"
                          VerticalAlignment="Center" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="7" IsSelected="True"/>
                    <ComboBoxItem Content="30"/>
                </ComboBox>

                <Button Content="Refresh" Padding="8,2" Margin="12,0,0,0"
                        Click="Refresh_Click"/>
                <Button Content="Purge Old Alerts" Padding="8,2" Margin="8,0,0,0"
                        Click="Purge_Click"/>
            </StackPanel>
        </Border>

        <!-- Status -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource ToolbarBg}" Height="24" Padding="10,0">
            <TextBlock x:Name="StatusText" Text="Loading..."
                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Alert list -->
        <ListView x:Name="AlertListView" FontSize="12"
                  Background="{DynamicResource PanelBg}"
                  BorderBrush="{DynamicResource BorderBrush}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Severity" Width="70"
                                    DisplayMemberBinding="{Binding Severity}"/>
                    <GridViewColumn Header="Category" Width="100"
                                    DisplayMemberBinding="{Binding Category}"/>
                    <GridViewColumn Header="Timestamp" Width="140"
                                    DisplayMemberBinding="{Binding CreatedAt}"/>
                    <GridViewColumn Header="Order" Width="120"
                                    DisplayMemberBinding="{Binding OrderId}"/>
                    <GridViewColumn Header="Summary" Width="320"
                                    DisplayMemberBinding="{Binding Summary}"/>
                </GridView>
            </ListView.View>
        </ListView>

    </DockPanel>
</Window>
